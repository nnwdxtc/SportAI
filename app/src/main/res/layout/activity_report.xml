<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 头部信息 -->
        <TextView
            android:id="@+id/tv_action"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/report_action"
            android:textSize="18sp"
            android:textColor="#000000"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tv_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/report_duration"
            android:textSize="18sp"
            android:textColor="#000000"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tv_similarity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/report_similarity"
            android:textSize="18sp"
            android:textColor="#000000"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tv_poses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/report_poses"
            android:textSize="18sp"
            android:textColor="#000000"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tv_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/report_count"
            android:textSize="18sp"
            android:textColor="#000000"
            android:paddingBottom="12dp"/>

        <!-- 折线图 -->
        <ImageView
            android:id="@+id/chart_view"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"/>
    </LinearLayout>
</ScrollView>
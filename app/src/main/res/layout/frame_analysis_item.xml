<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- 第一行：帧索引和选中标记 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvFrameIndex"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="实时帧#0"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvIsSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ 已匹配"
            android:visibility="gone"
            android:textSize="12sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- 第二行：匹配信息（简化为一行） -->
    <TextView
        android:id="@+id/tvMatchInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="匹配标准帧#-- (搜索范围:±20帧)"
        android:textSize="11sp"
        android:textColor="#1976D2"
        android:layout_marginBottom="6dp"
        android:visibility="gone"/>

    <!-- 第三行：角度对比 - 膝盖 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp"
        android:padding="4dp"
        android:background="#F0F8FF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="膝盖角度:"
            android:textSize="12sp"
            android:textColor="#333333"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvKneeInfo"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="实时 --° 匹配 --°"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- 第四行：角度对比 - 髋部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:padding="4dp"
        android:background="#FFF0F5">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="髋部角度:"
            android:textSize="12sp"
            android:textColor="#333333"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvHipInfo"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="实时 --° 匹配 --°"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- 第五行：相似度信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="6dp"
        android:padding="6dp"
        android:background="#F8F8F8">

        <!-- 相似度标题和进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvSimilarity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="匹配相似度: 0.0%"
                android:textSize="12sp"
                android:textColor="#2196F3"
                android:layout_marginEnd="8dp"/>

            <ProgressBar
                android:id="@+id/pbSimilarity"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"/>
        </LinearLayout>

        <!-- 详细相似度 -->
        <TextView
            android:id="@+id/tvSimilarityDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="膝盖相似度: 0.0% | 髋部相似度: 0.0%"
            android:textSize="10sp"
            android:textColor="#666666"/>
    </LinearLayout>

    <!-- 第六行：选择原因（简化） -->
    <TextView
        android:id="@+id/tvSelectionReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:textColor="#FF9800"
        android:padding="2dp"/>

</LinearLayout>
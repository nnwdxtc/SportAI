<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"

    android:padding="16dp"
    android:layout_margin="20dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_ai_assistant"
            app:tint="#87CEEB" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="AI 教练"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#87CEEB" />

        <ImageButton
            android:id="@+id/btn_close_dialog"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#999999" />
    </LinearLayout>

    <!-- 建议问题标签 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="你可以问我："
        android:textSize="12sp"
        android:textColor="#000000" />

    <!-- 建议问题按钮组 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_squat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="深蹲要领"
                android:textSize="12sp"
                app:chipBackgroundColor="#F0E6FF"
                app:chipStrokeColor="#E3F2FD"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_boxing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="拳击技巧"
                android:textSize="12sp"
                app:chipBackgroundColor="#F0E6FF"
                app:chipStrokeColor="#E3F2FD"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_plan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="训练计划"
                android:textSize="12sp"
                app:chipBackgroundColor="#F0E6FF"
                app:chipStrokeColor="#E3F2FD"
                app:chipStrokeWidth="1dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 聊天内容区域 -->
    <ScrollView
        android:id="@+id/scroll_chat"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="12dp"
        android:background="#F8F8F8"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/chat_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="你好！我是你的 AI 健身教练，有什么可以帮助你的吗？"
                android:textSize="14sp"
                android:textColor="#333333"
                android:background="@drawable/ai_message_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />
        </LinearLayout>
    </ScrollView>

    <!-- 输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_ai_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入你的问题..."
            android:textSize="14sp"
            android:maxLines="3"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#AAAAAA" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="#87CEEB"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- 加载指示器 -->
    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:indeterminateTint="#9933FF" />
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="?android:attr/selectableItemBackground"
    android:layout_marginBottom="4dp">

    <!-- 第一行：帧索引和选中标记 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvFrameIndex"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="实时帧#0"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvIsSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ 已匹配"
            android:visibility="gone"
            android:textSize="12sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- 第二行：匹配信息 -->
    <TextView
        android:id="@+id/tvMatchInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="匹配标准帧#--"
        android:textSize="11sp"
        android:textColor="#1976D2"
        android:layout_marginBottom="10dp"
        android:visibility="gone"/>

    <!-- 肘部对比区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        android:padding="10dp"
        android:background="#E3F2FD"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👊 肘部角度对比"
            android:textSize="13sp"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- 左肘 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="左肘:"
                android:textSize="12sp"
                android:textColor="#333333"
                android:layout_marginEnd="8dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvLeftElbow"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="实时 --° | 标准 --°"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 右肘 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="右肘:"
                android:textSize="12sp"
                android:textColor="#333333"
                android:layout_marginEnd="8dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvRightElbow"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="实时 --° | 标准 --°"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 肩部对比区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="10dp"
        android:padding="10dp"
        android:background="#F3E5F5"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💪 肩部角度对比"
            android:textSize="13sp"
            android:textColor="#7B1FA2"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- 左肩 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="左肩:"
                android:textSize="12sp"
                android:textColor="#333333"
                android:layout_marginEnd="8dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvLeftShoulder"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="实时 --° | 标准 --°"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 右肩 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="右肩:"
                android:textSize="12sp"
                android:textColor="#333333"
                android:layout_marginEnd="8dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvRightShoulder"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="实时 --° | 标准 --°"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 相似度信息区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="6dp"
        android:padding="10dp"
        android:background="#FFF3E0"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 相似度分析"
            android:textSize="13sp"
            android:textColor="#E65100"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- 总相似度 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvSimilarity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总相似度: 0.0%"
                android:textSize="12sp"
                android:textColor="#F57C00"
                android:textStyle="bold"
                android:layout_marginEnd="12dp"/>

            <ProgressBar
                android:id="@+id/pbSimilarity"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="10dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#FF9800"/>
        </LinearLayout>

        <!-- 详细相似度 -->
        <TextView
            android:id="@+id/tvSimilarityDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="左肘:0.0% 右肘:0.0% 左肩:0.0% 右肩:0.0%"
            android:textSize="11sp"
            android:textColor="#666666"/>
    </LinearLayout>

    <!-- 匹配原因 -->
    <TextView
        android:id="@+id/tvSelectionReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#5D4037"
        android:padding="6dp"
        android:background="#EFEBE9"
        android:layout_marginTop="4dp"/>

</LinearLayout>
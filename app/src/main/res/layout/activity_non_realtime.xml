<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.example.myapplication.NonRealtimeActivity">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/back_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:contentInsetStartWithNavigation="0dp"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp">
        <Button
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="重新比对"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button"
            app:backgroundTint="@null" />
        <!-- 开始比对 - 居中 -->
        <Button
            android:id="@+id/start_compare_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="开始比对"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button"
            app:backgroundTint="@null" />

        <!-- 生成报告 - 靠右 -->
        <Button
            android:id="@+id/btn_generate_report"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="生成报告"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button"
            app:backgroundTint="@null" />
    </RelativeLayout>
    <!-- 上传视频区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="上传视频"
            android:textAlignment="center"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 上传视频叠加容器 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.exoplayer2.ui.PlayerView
                android:id="@+id/uploadPlayerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false" />

            <!-- 上传视频角度显示 -->
            <com.example.myapplication.PixelPerfectOverlayView
                android:id="@+id/uploadOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />


            <LinearLayout
                android:id="@+id/uploadProgressOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#CCFFFFFF"
                android:visibility="gone">

                <TextView
                    android:id="@+id/uploadProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="处理上传视频..."
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/uploadProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="240dp"
                    android:layout_height="20dp"
                    android:progress="0" />

                <TextView
                    android:id="@+id/uploadProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@android:color/black"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </FrameLayout>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@android:color/darker_gray" />

    <!-- 标准视频区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="标准视频"
            android:textAlignment="center"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 标准视频叠加容器 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.exoplayer2.ui.PlayerView
                android:id="@+id/standardPlayerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false" />

            <com.example.myapplication.PixelPerfectOverlayView
                android:id="@+id/standardOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />


            <LinearLayout
                android:id="@+id/standardProgressOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#CCFFFFFF"
                android:visibility="gone">

                <TextView
                    android:id="@+id/standardProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="处理标准视频..."
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/standardProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="240dp"
                    android:layout_height="20dp"
                    android:progress="0" />

                <TextView
                    android:id="@+id/standardProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@android:color/black"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- 状态信息区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/similarityView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="相似度: --%"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold" />



        </LinearLayout>


        <TextView
            android:id="@+id/similarityBreakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@android:color/black" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#80000000"
        android:padding="8dp">

        <TextView
            android:id="@+id/progressTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="正在处理视频..."
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:gravity="center" />

        <ProgressBar
            android:id="@+id/videoProcessingProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginTop="8dp"
            android:progress="0" />

    </LinearLayout>

    <!-- 控制按钮区域（已移至底部） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_gravity="bottom"> <!-- 关键属性：固定在底部 -->

        <Button
            android:id="@+id/upload_video_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="上传比对视频"
            app:backgroundTint="@null"
            android:background="@drawable/gradient_button"
            android:textSize="14sp" />

        <Button
            android:id="@+id/select_standard_video_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="选择标准视频"
            app:backgroundTint="@null"
            android:background="@drawable/gradient_button"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context="com.example.myapplication.RealtimeActivity">

    <!-- 顶部工具栏 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/back_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:contentInsetStartWithNavigation="0dp"
        app:title="实时比对"
        app:titleTextColor="#333333"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 标准动作视频区域（上半部分） -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="true">

                <!-- 视频播放器 -->
                <com.google.android.exoplayer2.ui.PlayerView
                    android:id="@+id/exoPlayerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:use_controller="false"
                    app:show_buffering="when_playing"
                    app:animation_enabled="true"
                    app:resize_mode="fit"/>

                <!-- 视频覆盖层（骨骼点等） -->
                <com.example.myapplication.PixelPerfectOverlayView
                    android:id="@+id/videoOverlayView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    />

                <!-- 视频占位符（未加载时显示） -->
                <LinearLayout
                    android:id="@+id/videoPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#2C3E50"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="标准动作示范"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="视频加载中..."
                        android:textColor="#B0BEC5"
                        android:textSize="14sp" />

                    <ProgressBar
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:indeterminateTint="#FFFFFF" />
                </LinearLayout>

                <!-- 倍速控制悬浮按钮 -->
                <Button
                    android:id="@+id/btn_playback_speed"
                    android:layout_width="68dp"
                    android:layout_height="48dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="16dp"
                    android:drawableRight="@drawable/ic_speed"
                    android:contentDescription="调整播放速度"
                    app:backgroundTint="#000000"
                    />

                <!-- 静止状态提示 -->
                <LinearLayout
                    android:id="@+id/staticHintLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="#2563EB"
                    android:visibility="gone"
                    android:layout_gravity="bottom">

                    <TextView
                        android:id="@+id/staticHintView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未检测到运动，请开始动作"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/staticHintDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="角度变化小于5°，持续2秒以上"
                        android:textColor="#FFE0B2"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 视频处理进度 -->
                <LinearLayout
                    android:id="@+id/videoProgressOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#E6000000"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:indeterminateTint="#2563EB" />

                    <TextView
                        android:id="@+id/videoProgressText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="正在处理视频..."
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:id="@+id/videoProgressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#2563EB"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- 实时摄像头区域（下半部分） -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="true">

                <!-- 摄像头预览 -->
                <androidx.camera.view.PreviewView
                    android:id="@+id/viewFinder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    />

                <!-- 骨骼点覆盖层 -->
                <com.example.myapplication.OverlayView
                    android:id="@+id/overlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    />

                <!-- 左上角信息面板 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="start|top"
                    android:layout_margin="16dp">

                    <!-- 深蹲计数 -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#CC000000">

                        <LinearLayout
                            android:id="@+id/lyt_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="12dp"
                            android:paddingHorizontal="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/squatCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text=""
                                android:textColor="#B0BEC5"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 右上角切换摄像头按钮 -->
                <ImageButton
                    android:id="@+id/switch_camera_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|top"
                    android:layout_margin="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_camera_switch"
                    android:elevation="4dp"
                    android:contentDescription="切换摄像头"
                    app:tint="#FFFFFF" />

                <!-- 倒计时 -->
                <TextView
                    android:id="@+id/countdownText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="120sp"
                    android:textColor="#2563EB"
                    android:textStyle="bold"
                    android:shadowColor="#000000"
                    android:shadowRadius="10"
                    android:visibility="gone" />

                <!--                &lt;!&ndash; 开始提示遮罩 &ndash;&gt;-->
                <!--                <LinearLayout-->
                <!--                    android:id="@+id/startHintOverlay"-->
                <!--                    android:layout_width="match_parent"-->
                <!--                    android:layout_height="match_parent"-->
                <!--                    android:orientation="vertical"-->
                <!--                    android:gravity="center"-->
                <!--                    android:background="#CC000000"-->
                <!--                    android:visibility="visible">-->

                <!--                    <TextView-->
                <!--                        android:layout_width="wrap_content"-->
                <!--                        android:layout_height="wrap_content"-->
                <!--                        android:layout_marginTop="16dp"-->
                <!--                        android:text="点击开始运动"-->
                <!--                        android:textColor="#FFFFFF"-->
                <!--                        android:textSize="18sp"-->
                <!--                        android:textStyle="bold" />-->

                <!--                    <TextView-->
                <!--                        android:layout_width="wrap_content"-->
                <!--                        android:layout_height="wrap_content"-->
                <!--                        android:layout_marginTop="8dp"-->
                <!--                        android:text="请确保全身在画面内"-->
                <!--                        android:textColor="#B0BEC5"-->
                <!--                        android:textSize="14sp" />-->
                <!--                </LinearLayout>-->
            </FrameLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <Button
            android:id="@+id/select_video_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="选择视频"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/start_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="开始运动"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="28dp"
            app:backgroundTint="#2563EB"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />



    </LinearLayout>

    <!-- 比对结果按钮（浮动） -->
    <Button
        android:id="@+id/toggleVisualizationButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="88dp"
        android:text="显示比对图"
        android:visibility="gone"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF" />

    <!-- 可视化容器 -->
    <FrameLayout
        android:id="@+id/visualizationContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0" />
</LinearLayout>
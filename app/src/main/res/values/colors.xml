    <!-- 瑜伽 - 紫色系 -->
    <color name="category_yoga">#A855F7</color>
    <color name="category_yoga_bg">#F3E8FF</color>

    <!-- 有氧运动 - 绿色系 -->
    <color name="category_cardio">#22C55E</color>
